{
  "expo": {
    "name": "Assistant Courrier",
    "slug": "assistant-courrier",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "assistant-courrier",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f1efbf7d-fbd2-4aa7-ac91-63e552945e92"
      }
    },
    "android": {
      "package": "com.drcomputer60290.assistantcourrier"
    }
  }
}
